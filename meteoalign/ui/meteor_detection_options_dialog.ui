         <string>推理设备</string>
        </property>
       </widget>
      </item>
      <item row="4" column="1">
       <widget class="QComboBox" name="comboBoxProvider">
        <item><property name="text"><string>自动</string></property><property name="userData"><string>auto</string></property></item>
        <item><property name="text"><string>CPU</string></property><property name="userData"><string>cpu</string></property></item>
        <item><property name="text"><string>DirectML（Windows）</string></property><property name="userData"><string>dml</string></property></item>
        <item><property name="text"><string>CUDA</string></property><property name="userData"><string>cuda</string></property></item>
        <item><property name="text"><string>Core ML（macOS）</string></property><property name="userData"><string>coreml</string></property></item>
