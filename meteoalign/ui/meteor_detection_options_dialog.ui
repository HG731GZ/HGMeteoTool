      <item row="3" column="1">
       <widget class="QSpinBox" name="spinBoxPartition">
        <property name="minimum">
         <number>2</number>
        </property>
        <property name="maximum">
         <number>12</number>
        </property>
        <property name="value">
         <number>2</number>
